#include "inpa.h"

int g_result;
int g_a;
int g_b;
int g_c;

T12_nested_if()
{
  if (g_a > g_b) {
    if (g_b > g_c) {
      g_result = 1;
    } else {
      g_result = 2;
    }
  } else {
    if (g_a == g_c) {
      g_result = 3;
    } else {
      g_result = 4;
    }
  }
}

inpainit()
{
}

inpaexit()
{
}
