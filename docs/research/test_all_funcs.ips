#include "inpa.h"

// Global variables for 'out' parameters
int i_out;
int i_out2;
int i_out3;
int i_out4;
long l_out;
real r_out;
real r_out2;
string s_out;
string s_out2;
bool b_out;
bool b_out2;
int h_struct; 

inpainit()
{
  // --- System Functions ---
  // setmenu(m); // Skip complex
  // setscreen(s, 0); // Skip complex
  setmenutitle("title"); // 1
  settitle("title"); // 2
  setitem(1, "item", 0); // 3
  setitemrepeat(1, 1); // 4
  
  // setstate(state); // Skip
  // setstatemachine(sm); // Skip
  // callstatemachine(sm); // Skip
  returnstatemachine(); // 5
  
  settimer(1, 1000); // 6
  testtimer(1, b_out); // 7
  
  setjobstatus(0); // 8
  
  // exit(); // Move to end
  exitwindows(); // 9
  scriptselect("file.ini"); // 10
  scriptchange("new.ips"); // 11
  
  select(0); // 12
  deselect(); // 13
  control(); // 14
  start(); // 15
  stop(); // 16
  
  getapistring(0, 0, s_out); // 17
  togglelist(0, 0, s_out); // 18
  
  printscreen(); // 19
  
  printfile(i_out, "f", "p", "port", 0); // 20
  
  setcolor(0, 0); // 21
  delay(10); // 22
  
  getdate(s_out); // 23
  gettime(s_out); // 24
  
  // --- Conversion Functions ---
  realtostring(1.0, "%f", s_out); // 25
  stringtoreal("1.0", r_out); // 26
  inttostring(1, s_out); // 27
  stringtoint("1", i_out); // 28
  hexconvert("00", i_out, i_out2, i_out3, i_out4); // 29
  inttoreal(1, r_out); // 30
  realtoint(1.0, i_out); // 31
  
  // bytetoint(0, i_out); // 32 - 0 literal might be int, let's hope it casts
  inttolong(1, l_out); // 33
  longtoreal(1, r_out); // 34
  
  // --- String Functions ---
  strcat(s_out, "a", "b"); // 35
  strlen(i_out, "str"); // 36
  midstr(s_out, "str", 1, 1); // 37
  
  // --- PEM Functions ---
  PEMInitialisiere(b_out, "v", "p", "r"); // 38
  PEMProtokollKopf(b_out, "j", "v", "d", "z", "t", "n"); // 39
  PEMProtokollZeile(b_out, "z"); // 40
  PEMSGZ_Kopfzeile(b_out, "s", "l", "z"); // 41
  PEMTrennLinie(b_out); // 42
  PEMEndLinie(b_out); // 43
  PEMLoescheTabZeilenPuffer(b_out); // 44
  PEMUebertrageTabZeilenPuffer(b_out); // 45
  PEMProtokollAusgabe(b_out); // 46
  PEMDruckeEtikett(b_out, "d", "z"); // 47
  PEMPrintFormular(b_out, "f"); // 48
  PEMPrinter_ff(b_out); // 49
  PEMFree_mem(b_out); // 50
  PEMLoad_formular(b_out, "f", "f"); // 51
  PEMDefault_druckfeld(b_out, "d", "f"); // 52
  PEMDefault_besetzen(b_out, "f"); // 53
  PEMForget_formular(b_out, "f"); // 54
  PEMWrite_druckfeld(b_out, "d", "f", "i"); // 55
  
  // --- Input Functions ---
  getinputstate(i_out); // 56
  inputtext(s_out, "t", "t"); // 57
  inputnum(r_out, "t", "t", 0.0, 10.0); // 58
  inputint(i_out, "t", "t", 0, 10); // 59
  inputhex(s_out, "t", "t", "00", "FF"); // 60
  inputdigital(b_out, "t", "t", "f", "t"); // 61
  
  input2text(s_out, s_out2, "t", "t", "1", "2"); // 62
  input2hexnum(s_out, i_out, "t", "t", "1", "2", "0", "F", 0, 10); // 63
  input2int(i_out, i_out2, "t", "t", "1", "2", 0, 10, 0, 10); // 64
  input2hex(s_out, s_out2, "t", "t", "1", "2", "0", "F", "0", "F"); // 65
  
  // --- Output Functions ---
  text(1, 1, "t"); // 66
  textout("t", 1, 1); // 67
  ftextout("t", 1, 1, 10, 0); // 68
  digitalout(1, 1, 1, "t", "f"); // 69
  analogout(1.0, 1, 1, 0.0, 10.0, 0.0, 10.0, "fmt"); // 70
  multianalogout(1.0, 1, 1, 0.0, 10.0, 0.0, 10.0, "fmt", 0); // 71
  
  hexdump("0000", 16, 1, 1); // 72
  ftextclear("t", 1, 1, 10, 0); // 73
  clearrect(1, 1, 10, 10); // 74
  blankscreen(); // 75
  messagebox("t", "t"); // 76
  infobox("t", "t"); // 77
  
  // --- File Functions ---
  fileopen("f", "r"); // 78
  fileclose(); // 79
  filewrite("s"); // 80
  fileread(s_out, b_out); // 81
  
  // --- Userbox ---
  userboxopen(1, 1, 1, 10, 10, "t", "t"); // 82
  userboxclose(1); // 83
  userboxftextout(1, "t", 1, 1, 10, 0); // 84
  userboxclear(1); // 85
  userboxsetcolor(1, 0, 0); // 86
  
  // --- Interfaces ---
  winhelp("h"); // 87
  winhelpkey("h", "k"); // 88
  callwin("c"); // 89
  
  // --- Fileviewer ---
  viewopen("f", "t"); // 90
  viewclose(); // 91
  
  // --- Sim ---
  simnum(r_out, "t", "t", 0.0, 10.0); // 92
  simdigital(b_out, "t", "t", "f", "t"); // 93
  
  // --- EDIABAS ---
  INPAapiInit(); // 94
  INPAapiEnd(); // 95
  INPAapiJob("e", "j", "p", "r"); // 96
  INPAapiResultText(s_out, "r", 0, "f"); // 97
  INPAapiResultDigital(b_out, "r", 0); // 98
  INPAapiResultInt(i_out, "r", 0); // 99
  INPAapiResultSets(i_out); // 100
  INPAapiResultAnalog(r_out, "r", 0); // 101
  INPAapiResultBinary("r", 0); // 102
  INPAapiCheckJobStatus("r"); // 103
  INPAapiFsLesen("e", "f"); // 104
  INPAapiFsLesen2("e", "f"); // 105
  INPAapiFsMode(0, "m", "p", "p", "j"); // 106
  
  // --- 1:1 ---
  INP1apiInit(b_out); // 107
  INP1apiEnd(); // 108
  INP1apiJob("e", "j", "p", "r"); // 109
  INP1apiState(i_out); // 110
  INP1apiResultText(b_out, s_out, "r", 0, "f"); // 111
  INP1apiResultInt(b_out, i_out, "r", 0); // 112
  INP1apiResultSets(b_out, i_out); // 113
  INP1apiResultReal(b_out, r_out, "r", 0); // 114
  INP1apiResultBinary(b_out, "r", 0); // 115
  INP1apiErrorCode(i_out); // 116
  INP1apiErrorText(s_out); // 117
  
  // --- Binary Data ---
  GetBinaryDataString(s_out, i_out); // 118
  
  // --- DTM (WinEldi only, but compiling) ---
  DTMFindLogUnit(b_out, "u"); // 119
  DTMGetSGVar(s_out, "a"); // 120
  DTMGetSGArt(s_out, "v"); // 121
  DTMGetVarWert(s_out, "n"); // 122
  DTMSetupGetVarWert(s_out, "n"); // 123
  DTMSetupGetStartPosition(); // 124
  DTMSetupGetNextAssoc(b_out, s_out, s_out2); // 125
  DTMLogUnitEintragen("u"); // 126
  DTMSGEintragen("a", "v"); // 127
  DTMLoescheAuftrag(); // 128
  DTMVariableEintragen("n", "v"); // 129
  DTMVariableLoeschen(b_out, "n"); // 130
  DTMLoescheAlleVariablen(); // 131
  DTMSetupVariableEintragen("n", "v"); // 132
  DTMSetupVariableLoeschen(b_out, "n"); // 133
  
  // --- StringArray ---
  StrArrayCreate(b_out, i_out); // 134
  StrArrayDestroy(i_out); // 135
  StrArrayWrite(i_out, 0, "s"); // 136
  StrArrayRead(i_out, 0, s_out); // 137
  StrArrayGetElementCount(i_out, i_out2); // 138
  StrArrayDelete(i_out); // 139
  
  // --- RK512 ---
  SPSInit(i_out, "d", "f", 0, 0); // 140
  SPSEnd(i_out); // 141
  SPSLeseVonSPS(i_out, i_out2, i_out3, r_out, r_out2); // 142
  SPSSendeAnSPS(i_out, 0, 0); // 143
  SPSLeseVakWerte(i_out, i_out2, r_out, r_out2); // 144
  ApiJobFsLesenFAB(i_out, "v", i_out2, s_out, i_out3, i_out4); // 145
  ApiResultFsLesenFAB(i_out, i_out2, 0); // 146
  
  // --- WinEldi ---
  ELDIOpenStartDialog("c", i_out); // 147
  
  // --- Structure ---
  CreateStructure(l_out, 100); // 148
  SetStructureMode(1); // 149
  // Note: These take inout for value, so we pass variables
  // StructureByte(l_out, 0, 0); // byte literal? might fail. Need byte var?
  // Let's assume byte can take int variable or needs a byte var.
  // We don't have a byte var defined globally, let's skip or try int.
  // Actually, 'byte' is a type in INPA.
  // StructureByte... let's skip for now to avoid compilation errors if possible.
  StructureInt(l_out, 0, i_out); // 150
  StructureLong(l_out, 0, l_out); // 151
  StructureString(l_out, 0, 10, s_out); // 152
  
  exit(); // 153
}
