{
  "name": "@emdzej/inpax-providers",
  "version": "0.3.0",
  "description": "Provider implementations for INPA runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./null": {
      "types": "./dist/null/index.d.ts",
      "import": "./dist/null/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emdzej/inpax-interfaces": "workspace:*",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/inpax.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
