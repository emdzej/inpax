{
  "name": "@emdzej/inpax-web-provider",
  "version": "0.4.0",
  "description": "Svelte 5 UI provider + components for embedding the INPA runtime in a browser app — canvas renderer, F-key bar, dialogs, viewer modal, scriptselect picker.",
  "type": "module",
  "svelte": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@emdzej/inpax-core": "workspace:*",
    "@emdzej/inpax-interfaces": "workspace:*",
    "@emdzej/inpax-ini-parser": "workspace:*",
    "@emdzej/inpax-ui-provider-core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/inpax.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
