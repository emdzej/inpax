{
  "name": "@emdzej/inpax-ediabasx-provider",
  "version": "0.3.0",
  "description": "EdiabasX provider for INPA interpreter \u2014 uses @emdzej/ediabasx-ediabas for real ECU communication.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@emdzej/ediabasx-ediabas": "^0.1.3",
    "@emdzej/inpax-core": "workspace:*",
    "@emdzej/inpax-interfaces": "workspace:*",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/inpax.git"
  },
  "keywords": [
    "ediabas",
    "bmw",
    "diagnostics",
    "inpa",
    "obd"
  ]
}
