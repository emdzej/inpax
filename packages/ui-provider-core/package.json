{
  "name": "@emdzej/inpax-ui-provider-core",
  "version": "0.1.0",
  "description": "Abstract UI provider — shared state + IUIProvider implementation that TUI and Web subclasses build on.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@emdzej/inpax-interfaces": "workspace:*",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/inpax.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
