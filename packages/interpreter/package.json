{
  "name": "@emdzej/inpax-interpreter",
  "version": "0.1.0",
  "description": "INPA IPO bytecode interpreter",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "clean": "rm -rf dist/"
  },
  "keywords": [
    "inpa",
    "ipo",
    "interpreter",
    "bmw",
    "diagnostics"
  ],
  "license": "MIT",
  "dependencies": {
    "@emdzej/inpax-core": "workspace:*",
    "@emdzej/inpax-dispatcher": "workspace:*",
    "@emdzej/inpax-interfaces": "workspace:*",
    "@emdzej/inpax-logger": "workspace:*",
    "@emdzej/inpax-parser": "workspace:*",
    "@emdzej/inpax-providers": "workspace:*",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/inpax.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
