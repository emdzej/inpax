{
  "name": "@emdzej/inpax-web",
  "version": "0.1.0",
  "description": "Browser SPA for INPAX — pick an INPA install root, browse IPO scripts, run them against a live ECU via Web Serial. Pure client-side; no server.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "pwa-assets": "pwa-assets-generator",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@emdzej/ediabasx-ediabas": "^0.1.3",
    "@emdzej/ediabasx-interface-base": "^0.1.3",
    "@emdzej/ediabasx-interface-serial": "^0.1.3",
    "@emdzej/ediabasx-interfaces": "^0.1.3",
    "@emdzej/inpax-core": "workspace:*",
    "@emdzej/inpax-dispatcher": "workspace:*",
    "@emdzej/inpax-ediabasx-provider": "workspace:*",
    "@emdzej/inpax-ini-parser": "workspace:*",
    "@emdzej/inpax-interfaces": "workspace:*",
    "@emdzej/inpax-interpreter": "workspace:*",
    "@emdzej/inpax-logger": "workspace:*",
    "@emdzej/inpax-parser": "workspace:*",
    "@emdzej/inpax-providers": "workspace:*",
    "@emdzej/inpax-ui-provider-core": "workspace:*",
    "fflate": "^0.8.2",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/wicg-file-system-access": "^2023.10.5",
    "@vite-pwa/assets-generator": "^1.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
