{
  "name": "@emdzej/bimmerz-bundler",
  "version": "0.4.0",
  "description": "Curate a BMW software install (INPA / EDIABAS / NCS) into a small zip web tools (inpax-web, future ediabasx-web, future ncsx) can import into OPFS. Uses gitignore-style exclude patterns.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "bimmerz-bundle": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fflate": "^0.8.2",
    "ignore": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
